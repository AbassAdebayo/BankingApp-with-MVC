@using BankingApp.Models.DTOs
@using BankingApp.Models.DTOs.User
@model BaseResponse<CardInformationDto>

@{
    Layout = "_CustomerProfileLayout";
}

<style>
    .card-wrapper {
        width: 380px;
        height: 230px;
        perspective: 1000px;
        cursor: pointer;
        margin: 0 auto;
    }

    .card-inner {
        width: 100%;
        height: 100%;
        position: relative;
        transform-style: preserve-3d;
        transition: transform .8s ease;
    }

    .card-wrapper:hover .card-inner {
        transform: rotateY(180deg);
    }

    .atm-card {
        width: 100%;
        height: 100%;
        border-radius: 18px;
        padding: 25px;
        color: white;
        position: absolute;
        backface-visibility: hidden;
        font-family: 'Segoe UI', sans-serif;
        box-sizing: border-box;
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.25);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    /* MODERN GRADIENT EFFECT */
    .front {
        background: linear-gradient(145deg, #1e3c72, #2a5298);
        position: relative;
        overflow: hidden;
    }

        .front::after {
            content: "";
            position: absolute;
            width: 160%;
            height: 160%;
            top: -60%;
            left: -60%;
            background: radial-gradient(circle, rgba(255,255,255,0.15), transparent 70%);
            transform: rotate(35deg);
        }

    .back {
        background: linear-gradient(145deg, #444, #111);
        transform: rotateY(180deg);
        padding-right: 30px;
        padding-left: 20px;
    }

    /* FRONT ELEMENTS */
    .bank-name {
        font-size: 24px;
        font-weight: bold;
        margin-bottom: 10px;
    }

    .chip {
        width: 55px;
        height: 38px;
        border-radius: 8px;
        background: linear-gradient(135deg, gold, #d4b100);
        margin-top: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    }

    .card-number {
        font-size: 23px;
        letter-spacing: 3px;
        margin-top: 25px;
        font-weight: 500;
        z-index: 2;
    }

    .details-container {
        display: flex;
        justify-content: space-between;
        margin-top: 20px;
    }

    .label {
        font-size: 11px;
        text-transform: uppercase;
        opacity: .8;
    }

    .value {
        font-size: 14px;
        font-weight: bold;
    }

    /* BACK ELEMENTS */
    .magnetic-strip {
        width: 100%;
        height: 45px;
        margin-top: 15px;
        background: #000;
        border-radius: 4px;
    }

    .signature-box {
        background: white;
        width: 80%;
        height: 40px;
        margin: 20px auto 10px auto;
        border-radius: 4px;
        display: flex;
        align-items: center;
        padding: 6px 10px;
        justify-content: flex-end;
        box-shadow: inset 0 0 6px rgba(0,0,0,0.25);
    }

    .cvv-label {
        font-size: 11px;
        color: #444;
        font-weight: bold;
        margin-right: 8px;
    }

    .cvv-value {
        font-size: 15px;
        color: #000;
        font-weight: bold;
    }

    /* MOBILE FRIENDLY */
    @@media (max-width: 450px) {
        .card-wrapper {
            width: 95%;
            height: 210px;
        }

        .card-number {
            font-size: 20px;
        }

        .value {
            font-size: 13px;
        }
    }
</style>

<!DOCTYPE html>
<html>
<body>
    @if (!string.IsNullOrEmpty(ViewBag.Alert as string))
    {
        <div id="responseAlert" class="alert alert-@ViewBag.AlertType text-center" role="alert">
            @ViewBag.Alert
        </div>
        <script>
            document.addEventListener("DOMContentLoaded", () => {
                setTimeout(() => {
                    const alert = document.getElementById('responseAlert');
                    if (alert) {
                        alert.style.transition = "opacity 0.6s ease";
                        alert.style.opacity = 0;
                        setTimeout(() => alert.remove(), 600);
                    }
                }, 4000);
            });
        </script>
    }
    <div class="card-wrapper">
        <div class="card-inner">

            <!-- FRONT SIDE -->
            <div class="atm-card front">
                <div>
                    <div class="bank-name">@Model.Data.BankName</div>
                    <div class="chip"></div>
                </div>

                <div class="card-number">@Model.Data.CardNumber</div>

                <div class="details-container">
                    <div>
                        <div class="label">Card Holder</div>
                        <div class="value">@Model.Data.CardHolder</div>
                    </div>
                    <div>
                        <div class="label">Valid Till</div>
                        <div class="value">@Model.Data.Expiry</div>
                    </div>
                </div>
            </div>

            <!-- BACK SIDE -->
            <div class="atm-card back">
                <div class="magnetic-strip"></div>

                <div class="signature-box">
                    <span class="cvv-label"><i>cvv</i> </span>
                    <span class="cvv-value">@Model.Data.CardCVV</span>
                </div>
            </div>

        </div>
    </div>
</body>
</html>
